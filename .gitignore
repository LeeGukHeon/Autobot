autobot/models/**/*.pyo
logs/

# IDE / OS
.vscode/
.vs/
.idea/
.DS_Store
Thumbs.db

# --- allow source code under autobot/ even if broader ignore exists ---
!autobot/data/collect/
!autobot/data/collect/**

# Always ignore Python bytecode/cache everywhere.
**/__pycache__/
**/*.pyc
**/*.pyo
