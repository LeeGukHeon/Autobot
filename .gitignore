# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.pyo

# Build artifacts
build/
out/
*.egg-info/
compile_commands.json
python/site-packages/

# C++ / CMake / MSVC local build artifacts
cpp/build*/
cpp/**/CMakeFiles/
cpp/**/CMakeCache.txt
cpp/**/cmake_install.cmake
cpp/**/Testing/
*.vcxproj.user
*.VC.db
*.opendb
*.idb
*.pdb
*.ilk
*.obj
*.tlog
*.recipe
*.lastbuildstate

# Local environment
.env
.env.*
*.env
!config/secrets.example.env

# Project runtime artifacts
data/
!autobot/data/
autobot/data/*
!autobot/data/micro/
!autobot/data/micro/**
autobot/data/micro/__pycache__/
autobot/data/micro/**/*.pyc
models/
!autobot/models/
!autobot/models/**
autobot/models/**/__pycache__/
